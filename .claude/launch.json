{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server"],
      "port": 8090,
      "autoPort": true
    },
    {
      "name": "npx serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "3000", "."],
      "port": 3000
    },
    {
      "name": "local-1880",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "1880"],
      "port": 1880
    }
  ]
}
